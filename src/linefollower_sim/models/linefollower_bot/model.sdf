<?xml version="1.0"?>
<sdf version="1.8">
  <model name="linefollower_bot">
    <!-- Chassis: 20 x 14 x 5 cm box. Bottom sits at z=0.033 (wheel radius). -->
    <link name="chassis">
      <pose>0 0 0.058 0 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.00184</ixx>
          <iyy>0.00354</iyy>
          <izz>0.00497</izz>
        </inertia>
      </inertial>
      <visual name="chassis_visual">
        <geometry>
          <box><size>0.20 0.14 0.05</size></box>
        </geometry>
        <material>
          <ambient>0.1 0.3 0.8 1</ambient>
          <diffuse>0.1 0.3 0.8 1</diffuse>
        </material>
      </visual>
      <collision name="chassis_collision">
        <geometry>
          <box><size>0.20 0.14 0.05</size></box>
        </geometry>
      </collision>
    </link>

    <!-- Driven wheels: r=0.033, mounted toward the front -->
    <link name="left_wheel">
      <pose>0.055 0.0825 0.033 -1.5707 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.0000162</ixx>
          <iyy>0.0000162</iyy>
          <izz>0.0000272</izz>
        </inertia>
      </inertial>
      <visual name="left_wheel_visual">
        <geometry>
          <cylinder><radius>0.033</radius><length>0.025</length></cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="left_wheel_collision">
        <geometry>
          <cylinder><radius>0.033</radius><length>0.025</length></cylinder>
        </geometry>
      </collision>
    </link>

    <link name="right_wheel">
      <pose>0.055 -0.0825 0.033 -1.5707 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.0000162</ixx>
          <iyy>0.0000162</iyy>
          <izz>0.0000272</izz>
        </inertia>
      </inertial>
      <visual name="right_wheel_visual">
        <geometry>
          <cylinder><radius>0.033</radius><length>0.025</length></cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="right_wheel_collision">
        <geometry>
          <cylinder><radius>0.033</radius><length>0.025</length></cylinder>
        </geometry>
      </collision>
    </link>

    <!-- Rear caster: free-rolling sphere on a ball joint -->
    <link name="caster">
      <pose>-0.08 0 0.0165 0 0 0</pose>
      <inertial>
        <mass>0.02</mass>
        <inertia>
          <ixx>0.0000022</ixx>
          <iyy>0.0000022</iyy>
          <izz>0.0000022</izz>
        </inertia>
      </inertial>
      <visual name="caster_visual">
        <geometry>
          <sphere><radius>0.0165</radius></sphere>
        </geometry>
        <material>
          <ambient>0.5 0.5 0.5 1</ambient>
          <diffuse>0.5 0.5 0.5 1</diffuse>
        </material>
      </visual>
      <collision name="caster_collision">
        <geometry>
          <sphere><radius>0.0165</radius></sphere>
        </geometry>
      </collision>
    </link>

    <!-- x=0.105 puts the lens just past the chassis front edge (x=0.10)
         so the bottom of the frame sees ground, not the chassis top. -->
    <link name="camera_link">
      <pose>0.105 0 0.12 0 0.9599 0</pose>
      <inertial>
        <mass>0.02</mass>
        <inertia>
          <ixx>0.000002</ixx>
          <iyy>0.000002</iyy>
          <izz>0.000002</izz>
        </inertia>
      </inertial>
      <visual name="camera_visual">
        <geometry>
          <box><size>0.03 0.03 0.02</size></box>
        </geometry>
        <material>
          <ambient>0.8 0.2 0.2 1</ambient>
          <diffuse>0.8 0.2 0.2 1</diffuse>
        </material>
      </visual>
      <!-- 64x64 is the policy's input format — do not raise it. -->
      <sensor name="front_camera" type="camera">
        <topic>camera</topic>
        <update_rate>30</update_rate>
        <camera>
          <horizontal_fov>1.204</horizontal_fov>
          <image>
            <width>64</width>
            <height>64</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.01</near>
            <far>10</far>
          </clip>
        </camera>
      </sensor>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>left_wheel</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
      </axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>right_wheel</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
      </axis>
    </joint>

    <joint name="caster_joint" type="ball">
      <parent>chassis</parent>
      <child>caster</child>
    </joint>

    <joint name="camera_joint" type="fixed">
      <parent>chassis</parent>
      <child>camera_link</child>
    </joint>

    <plugin filename="ignition-gazebo-diff-drive-system"
            name="ignition::gazebo::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.165</wheel_separation>
      <wheel_radius>0.033</wheel_radius>
      <odom_publish_frequency>20</odom_publish_frequency>
      <topic>/cmd_vel</topic>
    </plugin>
  </model>
</sdf>
