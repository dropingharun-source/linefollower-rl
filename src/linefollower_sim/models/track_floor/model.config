<?xml version="1.0"?>
<model>
  <name>track_floor</name>
  <version>1.0</version>
  <sdf version="1.8">model.sdf</sdf>
  <description>
    4x4 m visual floor panel: white surface with the black track line
    painted on via materials/textures/track.png. Regenerate the texture
    with scripts/generate_track_texture.py. Visual only — collision comes
    from the world's ground plane.
  </description>
</model>
